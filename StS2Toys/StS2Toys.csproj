<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <TargetFramework>net10.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <EmbeddedResource Include="Resources\card_database.json" />
    <EmbeddedResource Include="Resources\card_types.json" />
    <EmbeddedResource Include="..\tools\extracted\localization\eng\cards.json"
                      LogicalName="StS2Toys.localization.eng.cards.json" />
    <EmbeddedResource Include="..\tools\extracted\localization\jpn\cards.json"
                      LogicalName="StS2Toys.localization.jpn.cards.json" />
    <EmbeddedResource Include="..\tools\extracted\localization\eng\relics.json"
                      LogicalName="StS2Toys.localization.eng.relics.json" />
    <EmbeddedResource Include="..\tools\extracted\localization\jpn\relics.json"
                      LogicalName="StS2Toys.localization.jpn.relics.json" />
  </ItemGroup>

</Project>