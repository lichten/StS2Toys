    <EmbeddedResource Include="..\tools\extracted\localization\jpn\encounters.json" LogicalName="StS2Toys.localization.jpn.encounters.json" />
    <EmbeddedResource Include="..\tools\extracted\localization\eng\acts.json" LogicalName="StS2Toys.localization.eng.acts.json" />
    <EmbeddedResource Include="..\tools\extracted\localization\jpn\acts.json" LogicalName="StS2Toys.localization.jpn.acts.json" />
