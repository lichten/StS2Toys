<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>WinExe</OutputType>
    <!-- ライブキャプチャ機能で WinRT（WGC/OCR）を使う StS2Capture.Core を参照するため
         SDK バージョン付き TFM に引上げ。 -->
    <TargetFramework>net10.0-windows10.0.19041.0</TargetFramework>
    <SupportedOSPlatformVersion>10.0.18362.0</SupportedOSPlatformVersion>
    <Nullable>enable</Nullable>
    <UseWindowsForms>true</UseWindowsForms>
    <ImplicitUsings>enable</ImplicitUsings>
  </PropertyGroup>

  <ItemGroup>
    <ProjectReference Include="..\StS2Shared\StS2Shared.csproj" />
    <ProjectReference Include="..\StS2Shared.Assets\StS2Shared.Assets.csproj" />
    <ProjectReference Include="..\StS2Capture.Core\StS2Capture.Core.csproj" />
  </ItemGroup>

  <ItemGroup>
    <!-- モンスター画像生成は StS2Shared.Spine 経由で SkiaSharp を使う。単一ファイル self-contained
         publish に native（libSkiaSharp）を確実に同梱するため、Win32 native を明示参照する保険。 -->
    <PackageReference Include="SkiaSharp.NativeAssets.Win32" Version="3.116.1" />
  </ItemGroup>

</Project>